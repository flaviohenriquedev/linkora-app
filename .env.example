# Copie para .env.local e preencha (não commite segredos).

# Supabase — URL pública do projeto
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Chave publicável (anon / publishable) — segura no front com RLS
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_or_publishable_key

# Opcional: nome alternativo aceito pelo código
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — APENAS servidor (API routes). Nunca exponha no cliente.
# Necessária para POST /api/auth/account-status (conta Google sem senha).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
